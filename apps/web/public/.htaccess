<IfModule mod_rewrite.c>
  RewriteEngine On

  # Let real files and folders resolve normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Hostinger/Apache fallback for static-exported dynamic routes.
  RewriteRule ^business/[^/]+/?$ /business/template/ [L]
  RewriteRule ^vendors/[^/]+/?$ /vendors/template/ [L]
  RewriteRule ^cities/[^/]+/?$ /cities/template/ [L]
  RewriteRule ^categories/[^/]+/?$ /categories/template/ [L]
  RewriteRule ^offers-events/[^/]+/?$ /offers-events/template/ [L]

  # SPA-style fallback for top-level pages handled by Next export.
  RewriteRule ^[^/]+/?$ /index.html [L]
</IfModule>
